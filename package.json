{
  "name": "quietclash",
  "version": "0.1.0",
  "description": "Catches the quiet clash — silent behavioral merge conflicts between parallel AI coding agents that merge cleanly and pass tests but break at runtime.",
  "type": "module",
  "bin": {
    "quietclash": "bin/quietclash.js"
  },
  "scripts": {
    "test": "node --test --test-concurrency=1",
    "bench": "node bench/eval.js"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "parallel-agents",
    "ai-agents",
    "agentic",
    "merge-conflict",
    "semantic-conflict",
    "behavioral-conflict",
    "behavioral-testing",
    "regression",
    "code-review",
    "git-worktree",
    "claude-code",
    "cursor",
    "codex"
  ],
  "license": "MIT",
  "author": "arbade",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arbade/quietclash.git"
  },
  "homepage": "https://github.com/arbade/quietclash#readme",
  "bugs": {
    "url": "https://github.com/arbade/quietclash/issues"
  },
  "files": [
    "bin/",
    "src/",
    "bench/",
    "examples/",
    "commands/",
    ".claude-plugin/",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@typescript-eslint/typescript-estree": "^8.0.0"
  },
  "optionalDependencies": {
    "@anthropic-ai/sdk": "^0.40.0"
  }
}
